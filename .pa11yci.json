{
  "urls": [
    "https://derechoartificial.com",
    "https://derechoartificial.com/jurisprudencia",
    "https://derechoartificial.com/firma-scarpa",
    "https://derechoartificial.com/recursos/guias",
    "https://derechoartificial.com/etica-ia",
    "https://derechoartificial.com/propiedad-intelectual-ia"
