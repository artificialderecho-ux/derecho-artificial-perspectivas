{
  "name": "derechoartificial-next",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next build --webpack && next-sitemap --config next-sitemap.config.cjs",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prebuild": "node scripts/validate-build-config.mjs && node scripts/convert-sfpro.mjs",
    "generate-md": "node scripts/generate-md-from-html.mjs",
    "deploy-content": "node scripts/deploy-content.mjs",
    "deploy-content:dry": "node scripts/deploy-content.mjs --dry",
    "test": "jest --coverage --testMatch=\"**/__tests__/**/*.test.tsx\"",
    "audit:a11y": "npx axe https://derechoartificial.com --output json --output-file a11y-reports/report.json",
    "verify-posts": "node scripts/verify-posts.mjs",
    "publish-post": "node scripts/publish-post.mjs",
    "revalidate": "node scripts/revalidate-api.mjs",
    "revalidate:home": "scripts/revalidate-home.bat",
    "revalidate:home:unix": "bash scripts/revalidate-home.sh",
    "interlinking": "node scripts/interlinking-complete-fixed.mjs",
    "interlinking:dry": "node scripts/interlinking-complete-fixed.mjs",
    "interlinking:apply": "node -e \"import('./scripts/interlinking-complete-fixed.mjs').then(m => { m.processFiles(); })\""
  },
