{
  "buildCommand": "NODE_OPTIONS='--max-old-space-size=4096' npm run build",
  "redirects": [
    {
      "source": "/fuentes/:path*",
      "destination": "https://raw.githubusercontent.com/artificialderecho-ux/derecho-artificial-perspectivas/main/public/fuentes/:path*",
      "permanent": false
    },
    {
      "source": "/Recursos/Fuentes/:path*",
      "destination": "https://raw.githubusercontent.com/artificialderecho-ux/derecho-artificial-perspectivas/main/public/Recursos/Fuentes/:path*",
      "permanent": false
    },
    {
      "source": "/assets/docs/:path*",
      "destination": "https://raw.githubusercontent.com/artificialderecho-ux/derecho-artificial-perspectivas/main/public/assets/docs/:path*",
      "permanent": false
    },
    {
      "source": "/big-brother-watch-analisis-cedh.pdf",
      "destination": "https://raw.githubusercontent.com/artificialderecho-ux/derecho-artificial-perspectivas/main/public/big-brother-watch-analisis-cedh.pdf",
      "permanent": false
    },
    {
      "source": "/sobre",
      "destination": "/quienes-somos",
      "permanent": true
    },
    {
      "source": "/manifiesto",
      "destination": "/quienes-somos",
      "permanent": true
    }
  ]
}
