# Variables de entorno para DerechoArtificial.com
# Copia este archivo a .env.local y ajusta los valores

# URL base del sitio
BASE_URL=https://www.derechoartificial.com

# Token secreto para revalidación de caché (Next.js)
# Genera un token seguro con: openssl rand -base64 32
REVALIDATE_SECRET=your_secure_random_token_here

# Variables de desarrollo (opcional)
NODE_ENV=development

# Variables de producción (descomentar en producción)
# NODE_ENV=production

# Variables para análisis (opcional)
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# VERCEL_ANALYTICS_ID=your_vercel_analytics_id

# Variables para API externas (opcional)
# API_SECRET_KEY=your_api_secret_key
